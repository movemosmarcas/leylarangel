---
import './SoyLeyla.css';
import Btn from '../../atoms/Btn/Btn.astro';
---

<section class="o-soy-leyla" id="sobre-mi">
  <div class="o-soy-leyla__container">
    <div class="o-soy-leyla__image-wrapper">
      <img src="/img/leyla-bn.png" alt="Leyla Rangel" class="o-soy-leyla__image" />
    </div>
    
    <div class="o-soy-leyla__content">
      <span class="o-soy-leyla__tag">Sobre mí</span>
      <h2 class="o-soy-leyla__title">SOY LEYLA RANGEL</h2>
      <div class="o-soy-leyla__bio">
        <p>
          Con más de <span class="o-soy-leyla__accent">33 años de trayectoria</span>, he prestado mi voz para dar vida a personajes icónicos en el cine y la televisión. Mi pasión es contar historias a través de la interpretación vocal, fusionando técnica y emoción para conectar con audiencias de todo el mundo. Desde grandes producciones de <span class="o-soy-leyla__accent">Disney</span> hasta campañas publicitarias globales.
        </p>
      </div>
      <div class="o-soy-leyla__cta-container">
        <Btn text="Conoce más sobre mí" url="/sobre-mi" variant="secondary" className="o-soy-leyla__btn" />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initSoyLeylaAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    let mm = gsap.matchMedia();

    mm.add("(min-width: 993px)", () => {
      // 1. Entrance animation for the image wrapper (Unroll effect)
      gsap.fromTo('.o-soy-leyla__image-wrapper',
        {
          clipPath: 'inset(0% 0% 100% 0%)',
          y: -40,
          opacity: 0
        },
        {
          clipPath: 'inset(0% 0% 0% 0%)',
          y: 0,
          opacity: 1,
          duration: 1.4,
          ease: 'power4.out',
          scrollTrigger: {
            trigger: '.o-soy-leyla__container',
            start: 'top 80%',
            toggleActions: 'play none none reverse'
          }
        }
      );

      // 2. Subtle internal image parallax on scroll
      gsap.to('.o-soy-leyla__image', {
        yPercent: 20, // moves the image downwards inside its wrapper as you scroll
        ease: 'none',
        scrollTrigger: {
          trigger: '.o-soy-leyla__image-wrapper',
          start: 'top bottom',
          end: 'bottom top',
          scrub: true
        }
      });

      // 3. Subtle, elegant staggered reveal for the text content
      gsap.from('.o-soy-leyla__content > *', {
        scrollTrigger: {
          trigger: '.o-soy-leyla__content',
          start: 'top 80%',
          toggleActions: 'play none none reverse'
        },
        y: 40,
        opacity: 0,
        duration: 1.2,
        stagger: 0.15,
        ease: 'power3.out'
      });
    });

    mm.add("(max-width: 992px)", () => {
      const mobileTl = gsap.timeline({
        scrollTrigger: {
          trigger: '.o-soy-leyla',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        }
      });

      mobileTl.fromTo('.o-soy-leyla__image-wrapper',
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 1, ease: 'power2.out' }
      );
      
      mobileTl.fromTo('.o-soy-leyla__content > *',
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.8, stagger: 0.1, ease: 'power2.out' },
        "-=0.5"
      );
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSoyLeylaAnimations);
  } else {
    initSoyLeylaAnimations();
  }
  document.addEventListener('astro:page-load', initSoyLeylaAnimations);
</script>
