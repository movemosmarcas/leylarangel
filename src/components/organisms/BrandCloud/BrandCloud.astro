---
import './BrandCloud.css';

const brands = [
  { name: 'Disney', logo: 'https://upload.wikimedia.org/wikipedia/commons/3/3e/Disney_2011.svg' },
  { name: 'Netflix', logo: 'https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg' },
  { name: 'HBO Max', logo: 'https://upload.wikimedia.org/wikipedia/commons/1/17/HBO_Max_Logo.svg' },
  { name: 'Warner Bros', logo: 'https://upload.wikimedia.org/wikipedia/commons/6/64/Warner_Bros_logo.svg' },
  { name: 'Nickelodeon', logo: 'https://upload.wikimedia.org/wikipedia/commons/e/ec/Nickelodeon_2023.svg' },
  { name: 'Cartoon Network', logo: 'https://upload.wikimedia.org/wikipedia/commons/8/80/Cartoon_Network_2010_logo.svg' },
  { name: 'Sony', logo: 'https://upload.wikimedia.org/wikipedia/commons/c/ca/Sony_logo.svg' },
  { name: 'Pixar', logo: 'https://upload.wikimedia.org/wikipedia/commons/2/2e/Pixar_Logo.svg' },
];
---

<section class="o-brand-cloud">
  <div class="o-brand-cloud__container">
    <div class="o-brand-cloud__carousel">
      <div class="o-brand-cloud__track">
        {[...brands, ...brands, ...brands, ...brands].map((brand) => (
          <div class="o-brand-cloud__card">
            <img src={brand.logo} alt={brand.name} class="o-brand-cloud__logo" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
