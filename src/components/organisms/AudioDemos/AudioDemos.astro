---
import './AudioDemos.css';

const demos = [
  { 
    id: 'comercial',
    title: 'COMERCIAL', 
    description: 'Voz institucional, fresca y versátil para las marcas más prestigiosas.',
    file: '/audio/demo-comercial.mp3' 
  },
  { 
    id: 'doblaje',
    title: 'DOBLAJE', 
    description: 'Interpretación de personajes icónicos con alma y profundidad emocional.',
    file: '/audio/demo-doblaje.mp3' 
  }
];
---

<section class="o-audio-demos">
  <div class="o-audio-demos__container">
    <header class="o-audio-demos__header">
      <span class="o-audio-demos__tagline">/ REELS DE VOZ</span>
      <h2 class="o-audio-demos__title">ESCUCHA MI TRABAJO</h2>
    </header>

    <div class="o-audio-demos__list">
      {demos.map((demo) => (
        <div class="o-audio-demos__item" data-audio-id={demo.id}>
          <div class="o-audio-demos__info">
            <h3 class="o-audio-demos__item-title">{demo.title}</h3>
            <p class="o-audio-demos__item-description">{demo.description}</p>
          </div>
          
          <div class="m-custom-player">
            <audio id={`audio-${demo.id}`} src={demo.file}></audio>
            
            <button class="m-custom-player__play-btn" aria-label="Reproducir">
              <span class="m-custom-player__icon-play">▶</span>
              <span class="m-custom-player__icon-pause" style="display: none;">‖</span>
            </button>
            
            <div class="m-custom-player__progress-container">
              <div class="m-custom-player__progress-bar">
                <div class="m-custom-player__progress-fill"></div>
              </div>
            </div>
            
            <div class="m-custom-player__time">
              <span class="m-custom-player__current">0:00</span>
              <span class="m-custom-player__separator">/</span>
              <span class="m-custom-player__duration">0:00</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.o-audio-demos__item').forEach(item => {
    const audioId = item.getAttribute('data-audio-id');
    const audio = item.querySelector(`#audio-${audioId}`) as HTMLAudioElement;
    const playBtn = item.querySelector('.m-custom-player__play-btn');
    const playIcon = item.querySelector('.m-custom-player__icon-play') as HTMLElement;
    const pauseIcon = item.querySelector('.m-custom-player__icon-pause') as HTMLElement;
    const progressFill = item.querySelector('.m-custom-player__progress-fill') as HTMLElement;
    const currentTimeEl = item.querySelector('.m-custom-player__current');
    const durationEl = item.querySelector('.m-custom-player__duration');

    const formatTime = (time: number) => {
      const minutes = Math.floor(time / 60);
      const seconds = Math.floor(time % 60);
      return `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
    };

    audio.addEventListener('loadedmetadata', () => {
      if (durationEl) durationEl.textContent = formatTime(audio.duration);
    });

    playBtn?.addEventListener('click', () => {
      // Pause all other audios
      document.querySelectorAll('audio').forEach(otherAudio => {
        if (otherAudio !== audio) {
          otherAudio.pause();
          const otherItem = otherAudio.closest('.o-audio-demos__item');
          if (otherItem) {
            (otherItem.querySelector('.m-custom-player__icon-play') as HTMLElement).style.display = 'block';
            (otherItem.querySelector('.m-custom-player__icon-pause') as HTMLElement).style.display = 'none';
          }
        }
      });

      if (audio.paused) {
        audio.play();
        playIcon.style.display = 'none';
        pauseIcon.style.display = 'block';
      } else {
        audio.pause();
        playIcon.style.display = 'block';
        pauseIcon.style.display = 'none';
      }
    });

    audio.addEventListener('timeupdate', () => {
      const progress = (audio.currentTime / audio.duration) * 100;
      if (progressFill) progressFill.style.width = `${progress}%`;
      if (currentTimeEl) currentTimeEl.textContent = formatTime(audio.currentTime);
    });

    audio.addEventListener('ended', () => {
      playIcon.style.display = 'block';
      pauseIcon.style.display = 'none';
      if (progressFill) progressFill.style.width = '0%';
    });
  });
</script>
