---
import './Comercial.css';
---

<section class="o-comercial" id="comercial">
  <div class="o-comercial__container">

    <div class="o-comercial__header">
      <div class="o-comercial__header-image">
        <div class="o-comercial__gif-sequence">
          <img src="/img/logo1.png" alt="Leyla Rangel Animación 1" class="o-comercial__gif-frame frame-1" />
          <img src="/img/logo2.png" alt="Leyla Rangel Animación 2" class="o-comercial__gif-frame frame-2" />
          <img src="/img/logo3.png" alt="Leyla Rangel Animación 3" class="o-comercial__gif-frame frame-3" />
        </div>
      </div>
      <div class="o-comercial__header-text">
        <span class="o-comercial__subtitle">Locución Comercial</span>
        <h2 class="o-comercial__title">La Voz que<br /><em>Mueve Marcas</em></h2>
        <p class="o-comercial__intro">
          Con más de <strong>33 años</strong> conectando marcas con audiencias a través del poder de mi voz, llevo mis interpretaciones desde grandes corporativos hasta campañas globales. Para mí, la locución comercial es el arte de comunicar en segundos lo que una marca representa para siempre.
        </p>
      </div>
    </div>

    <div class="o-comercial__body">
      <!-- Top section: Brands Grid -->
      <div class="o-comercial__brands">
        <p class="o-comercial__brands-title">Marcas con las que he colaborado</p>
        <div class="o-comercial__brands-grid">
          {[
            'Disney', 'Pixar', 'Dreamworks', 'Ghibli', 'Marvel',
            'Warner', 'Sony', 'Netflix', 'Mercedes Benz', 'Coca Cola',
            'Telcel', 'Target', 'Naturella', 'Evenflo', 'Mattel'
          ].map((brand) => (
            <span class="o-comercial__brand-pill">{brand}</span>
          ))}
        </div>
      </div>

      <!-- Bottom section: Currently on air + Image Card -->
      <div class="o-comercial__currently-card">
        <div class="o-comercial__currently-image">
          <img src="/img/leyla-y-micro.png" alt="Leyla en cabina grabando" class="o-comercial__img-micro" />
        </div>
        <div class="o-comercial__currently-content">
          <span class="o-comercial__currently-label">Actualmente en el aire</span>
          <div class="o-comercial__currently-grid">
            {['Allegra', 'Mac & Cheese de Kraft', 'AutoZone', "M&M's Verde", "L'Oréal", 'Coppel'].map((brand) => (
              <div class="o-comercial__current-item">
                <span class="o-comercial__current-dot"></span>
                <span class="o-comercial__current-name">{brand}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initComercialAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo('.o-comercial__header-image',
      { opacity: 0, x: -40, filter: 'blur(10px)' },
      {
        opacity: 1, x: 0, filter: 'blur(0px)', duration: 1.2, ease: 'power3.out',
        scrollTrigger: {
          trigger: '.o-comercial',
          start: 'top 80%',
          toggleActions: 'play none none reverse'
        }
      }
    );

    gsap.fromTo('.o-comercial__header-text > *',
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 1, stagger: 0.15, ease: 'power3.out',
        scrollTrigger: {
          trigger: '.o-comercial',
          start: 'top 80%',
          toggleActions: 'play none none reverse'
        }
      }
    );

    gsap.fromTo('.o-comercial__brands',
      { opacity: 0, y: 50 },
      {
        opacity: 1, y: 0, duration: 1, stagger: 0.2, ease: 'power3.out',
        scrollTrigger: {
          trigger: '.o-comercial__body',
          start: 'top 85%',
          toggleActions: 'play none none reverse'
        }
      }
    );

    // Card Unroll Reveal
    const cardTl = gsap.timeline({
      scrollTrigger: {
        trigger: '.o-comercial__currently-card',
        start: 'top 85%',
        toggleActions: 'play none none reverse'
      }
    });

    cardTl.fromTo('.o-comercial__currently-card',
      { clipPath: 'inset(0% 100% 0% 0%)' }, // Wipe from left to right
      { clipPath: 'inset(0% 0% 0% 0%)', duration: 1.2, ease: 'power4.inOut' }
    )
    .fromTo('.o-comercial__currently-label',
      { opacity: 0, x: -20 },
      { opacity: 1, x: 0, duration: 0.6, ease: 'power2.out' },
      '-=0.4'
    )
    .fromTo('.o-comercial__current-item',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, stagger: 0.1, duration: 0.6, ease: 'back.out(1.2)' },
      '-=0.4'
    );

    // Image Parallax Effect (Removed per user request)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initComercialAnimations);
  } else {
    initComercialAnimations();
  }
  document.addEventListener('astro:page-load', initComercialAnimations);
</script>
